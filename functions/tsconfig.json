{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "types": ["@cloudflare/workers-types"],
    "noEmit": true
  },
  "include": ["./**/*.ts", "../src/utils/generate.ts", "../src/utils/name_model.json"]
}
